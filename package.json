{
  "name": "supon-kielce-platforma",
  "version": "1.0.0",
  "description": "Platforma Obsługi Klienta SUPON Kielce",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.supon.platforma",
    "productName": "SuponKielcePlatforma",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "dashboard.html",
      "karta-pracownika.html",
      "nowe-zamowienie.html",
      "personel.html",
      "wz.html",
      "zamowienia.html",
      "zgloszenia.html",
      "app.js",
      "components.js",
      "mock-data.js",
      "styles.css",
      "logo.png",
      "foto/**/*",
      "main.js"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    }
  }
}
